RewriteEngine On

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(png|jpe?g|webp|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

RewriteRule ^sitemap\.xml$ sitemap.php [QSA,L]
RewriteRule ^artists/?$ list_artist.php [QSA,L]
RewriteRule ^genres/?$ list_genre.php [QSA,L]
RewriteRule ^countries/?$ music_tourism.php [QSA,L]
RewriteRule ^artist/([^/]+)/?$ artist.php?slug=$1 [QSA,L,B]
RewriteRule ^genre/([^/]+)/?$ genre.php?slug=$1 [QSA,L,B]
RewriteRule ^year/([0-9]{4})/?$ song_year.php?year=$1 [QSA,L]
RewriteRule ^country/([A-Za-z]{2})/?$ music_tourism.php?country=$1 [QSA,L]
RewriteRule ^page/([^/]+)/?$ index.php?page=$1 [QSA,L,B]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/(index|song|artist|genre|song_year|list_artist|list_genre|music_tourism|profile|social-login|oauth-callback|paypal-create|paypal-return|sitemap)\.php
RewriteRule ^([^/]+)/?$ song.php?id=$1 [QSA,L,B]
